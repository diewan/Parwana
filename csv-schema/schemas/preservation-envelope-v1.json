{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PreservationEnvelopeV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "object_registry_id", "original_canonical_bytes_hex", "algorithm_ids", "preserved_at", "previous_envelope_id_hex", "renewal_material_digest_hex"],
  "properties": {
    "version": {"type": "integer", "const": 1},
    "object_registry_id": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[ -~]+$"},
    "original_canonical_bytes_hex": {"type": "string", "minLength": 2, "maxLength": 16777216, "pattern": "^([0-9a-f]{2})+$"},
    "algorithm_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[ -~]+$"}
    },
    "preserved_at": {"type": "integer", "minimum": 1},
    "previous_envelope_id_hex": {
      "oneOf": [
        {"type": "null"},
        {"type": "string", "minLength": 64, "maxLength": 64, "pattern": "^[0-9a-f]{64}$"}
      ]
    },
    "renewal_material_digest_hex": {"type": "string", "minLength": 64, "maxLength": 64, "pattern": "^[0-9a-f]{64}$"}
  }
}
