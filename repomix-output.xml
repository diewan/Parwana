web-sys = { workspace = true, features = ["Window", "Storage"], optional = true }
js-sys = { version = "0.3", optional = true }

# Error handling
thiserror = "1.0"

# Directory resolution for file keystore (native-only)
[target.'cfg(not(target_arch = "wasm32"))'.dependencies]
dirs = "5.0"

[features]
default = ["bip44", "secp256k1"]
bip44 = ["bip32", "secp256k1", "ed25519-dalek", "bitcoin", "blake2", "bs58"]
secp256k1 = ["dep:secp256k1"]
ed25519 = ["ed25519-dalek"]
bitcoin = ["dep:bitcoin"]
blake2 = ["dep:blake2"]
wasm = ["getrandom/js", "argon2", "web-sys", "js-sys"]
production = ["argon2"]

[dev-dependencies]
tempfile = "3.9"
