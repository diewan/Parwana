# quorum = ["reqwest", "url"]  # REMOVED: quorum support is not active in this adapter
production = ["rpc"]
test-utils = []

[build-dependencies]
serde_json = "1.0"

[dev-dependencies]
rand = "0.8"
tokio = { version = "1", features = ["rt", "macros"] }
