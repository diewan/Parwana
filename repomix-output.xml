<file path=".github/workflows/architecture.yml">
name: Architectural Constitution

on:
  push:
    branches: [ main, develop ]
  pull_request:
    branches: [ main, develop ]

jobs:
  constitution:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Install cargo-deny
        run: cargo install cargo-deny

      - name: Check dependency graph constitution
        run: cargo deny check graph

      - name: Run dependency DAG test
        run: CXXFLAGS="-include cstdint" cargo test -p csv-architecture --test dep_graph_constitution

      - name: No tokio::runtime::Builder in adapters
        run: |
          count=$(grep -rn "tokio::runtime::Builder" csv-adapters/ 2>/dev/null | wc -l)
          if [ "$count" -ne 0 ]; then
            echo "FAIL: $count runtime construction sites in adapters"
            grep -rn "tokio::runtime::Builder" csv-adapters/
            exit 1
          fi

      - name: No block_on outside binaries and tests
        run: |
          violations=$(grep -rn "\.block_on(" csv-*/src/ \
            --exclude-dir=csv-cli --exclude-dir=csv-sdk 2>/dev/null | grep -v "#\[cfg(test)\]" || true)
          if [ -n "$violations" ]; then
            echo "FAIL: block_on found outside of binaries and tests"
            echo "$violations"
            exit 1
          fi

      - name: Adapter configs must use csv-adapter-core
        run: |
          for adapter in csv-adapters/csv-*; do
            if [ "$adapter" = "csv-adapters/csv-adapter-core" ]; then
              continue
            fi
            if [ -f "$adapter/Cargo.toml" ]; then
              if ! grep -q "csv-adapter-core" "$adapter/Cargo.toml"; then
                echo "FAIL: $adapter does not depend on csv-adapter-core"
                exit 1
              fi
            fi
          done

      - name: Removed deployment template stays removed
        run: test ! -d deployment

      - name: Run existing architecture guard tests
        run: CXXFLAGS="-include cstdint" cargo test -p csv-architecture --test architecture_guard

      - name: Run CLI architecture compliance tests
        run: CXXFLAGS="-include cstdint" cargo test -p csv-cli --test architecture_compliance

  formal-verification:
    name: Formal model check
    runs-on: ubuntu-24.04
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: '17'

      - name: Download formal verification tools
        run: |
          curl --fail --location --silent --show-error \
            --output /tmp/tla2tools.jar \
            https://github.com/tlaplus/tlaplus/releases/latest/download/tla2tools.jar
          curl --fail --location --silent --show-error \
            --output /tmp/alloy.jar \
            https://github.com/AlloyTools/org.alloytools.alloy/releases/download/v6.2.0/org.alloytools.alloy.dist.jar

      - name: Check TLA+ models
        run: |
          java -cp /tmp/tla2tools.jar tlc2.TLC -deadlock -config formal/ReplaySafety.cfg formal/ReplaySafety.tla
          java -cp /tmp/tla2tools.jar tlc2.TLC -config formal/Ownership.cfg formal/Ownership.tla

      - name: Execute Alloy analyses
        run: java -jar /tmp/alloy.jar exec -q -f -o /tmp/csv-alloy-replay -c '*' formal/alloy/ReplaySafety.als
</file>

